# Configuración de Conexión PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=imdc_2026
DB_USER=postgres
DB_PASSWORD=postgres

# Ruta de almacenamiento de datos locales
DATA_DIR=data

# ---- Envío de predicciones a Mosqlimate (scripts/submit_mosqlient.py) ----
# Obtén tu API key en https://api.mosqlimate.org (perfil de usuario)
API_KEY=tu_api_key_aqui
# Repositorio público del modelo (usuario/repo)
REPOSITORY=germanavila09/3rd_imdc_universidad_del_valle_grupo_modelamiento_datos_dengue
# Hash del commit con el que se registra el modelo (se obtiene tras hacer push)
COMMIT=pega_aqui_el_hash_del_commit
